generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  createdAt    DateTime   @default(now())
  favorites    Favorite[]
  ratings      Rating[]
  comments     Comment[]
}

model Recipe {
  id                String             @id @default(cuid())
  slug              String             @unique
  title             String
  description       String
  imageEmoji        String
  cookTimeMinutes   Int
  servings          Int
  // Steps and tags stay as JSON text - no need to query across individual
  // steps/tags independently of their recipe. Ingredients are normalized
  // (see RecipeIngredient/Ingredient below) so "what can I cook with X"
  // can search by canonical ingredient name instead of noisy free text.
  steps             String
  tags              String
  createdAt         DateTime           @default(now())
  favorites         Favorite[]
  ratings           Rating[]
  comments          Comment[]
  recipeIngredients RecipeIngredient[]
  translations      RecipeTranslation[]
}

// Translated title/description/steps for one recipe in one language (e.g.
// locale "bg" for Bulgarian). Recipes without a row here for the requested
// locale fall back to the original English fields - translation coverage
// can grow incrementally without breaking untranslated recipes.
model RecipeTranslation {
  id          String @id @default(cuid())
  recipeId    String
  locale      String
  title       String
  description String
  steps       String // JSON array, same shape as Recipe.steps
  recipe      Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, locale])
}

// Canonical ingredient name (e.g. "red pepper", "ground beef") - shared
// across recipes so a search for one ingredient finds every recipe that
// uses it, regardless of how that recipe's own text happens to phrase it.
model Ingredient {
  id                String             @id @default(cuid())
  name              String             @unique
  recipeIngredients RecipeIngredient[]
}

// One ingredient line within one recipe. displayText is the exact original
// line ("1 lb ground beef") shown on the recipe page; ingredientId is what
// ingredient-based search actually matches against. position preserves the
// original ingredient list order (relational rows have no implicit order).
// quantity is the parsed leading amount (e.g. 1 for "1 onion, diced", 0.5
// for "1/2 lemon, juiced") - null when the line has no clean numeric amount
// ("Salt to taste") - used to rank ingredient-search matches by how much of
// that ingredient a recipe actually uses.
model RecipeIngredient {
  id           String     @id @default(cuid())
  recipeId     String
  ingredientId String
  displayText  String
  quantity     Float?
  position     Int
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  translations RecipeIngredientTranslation[]

  @@index([ingredientId])
}

// Translated displayText for one ingredient line in one language. Search
// still matches against the canonical (English) Ingredient.name regardless
// of locale - only what's shown on the page is translated.
model RecipeIngredientTranslation {
  id                 String           @id @default(cuid())
  recipeIngredientId String
  locale             String
  displayText        String
  recipeIngredient   RecipeIngredient @relation(fields: [recipeIngredientId], references: [id], onDelete: Cascade)

  @@unique([recipeIngredientId, locale])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  value     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  body      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}
